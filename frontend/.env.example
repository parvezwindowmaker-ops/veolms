# Frontend environment (Vite). Copy to .env for local overrides.

# Backend API base URL. Leave UNSET in dev, since Vite proxies '/api' to
# http://localhost:3000 (see vite.config.ts). In production set this to the
# deployed backend, including the /api suffix, e.g.:
# VITE_API_URL=https://veolms-api.onrender.com/api
